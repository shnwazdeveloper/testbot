# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# MongoDB Connection URI (MongoDB Atlas recommended for Render)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/telegrambot?retryWrites=true&w=majority

# Port (Render sets this automatically)
PORT=3000

# Bot Admin Telegram User ID (optional)
ADMIN_ID=123456789
